# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mywarden:mywarden@localhost:5432/mywarden
POSTGRES_USER=mywarden
POSTGRES_PASSWORD=mywarden
POSTGRES_DB=mywarden

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# ── Redis (added in Phase 3) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object storage (local = MinIO, prod = AWS S3) ─────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=mywarden-enrollments
S3_ENDPOINT_URL=http://localhost:9000   # leave blank when using real AWS S3

# ── Face recognition ──────────────────────────────────────────────────────────
DEEPFACE_MODEL=Facenet512
FACE_MATCH_THRESHOLD=0.80

# ── MinIO local dev ───────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
